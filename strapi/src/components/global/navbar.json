{
  "collectionName": "components_global_navbars",
  "info": {
    "displayName": "Navbar",
    "icon": "bold"
  },
  "options": {},
  "attributes": {
    "logo": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::logo.logo"
    },
    "top_navbar": {
      "type": "component",
      "component": "items.top-navbar-items",
      "repeatable": true,
      "required": true
    },
    "bottom_navbar": {
      "type": "component",
      "component": "items.bottom-navbar-items",
      "repeatable": true,
      "required": true
    },
    "show_search": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "search_placeholder": {
      "type": "string",
      "default": "search our site"
    }
  }
}
